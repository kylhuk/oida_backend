<clickhouse>
    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
        </default>
        <svc_bootstrap>
            <password>bootstrap_change_me</password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <grants>
                <query>GRANT ALL ON *.* WITH GRANT OPTION</query>
                <query>GRANT osint_admin</query>
            </grants>
        </svc_bootstrap>
    </users>
    <roles>
        <osint_admin>
            <grants>
                <query>GRANT ALL ON *.*</query>
            </grants>
        </osint_admin>
    </roles>
    <profiles>
        <default>
            <allow_experimental_database_materialized_mysql>1</allow_experimental_database_materialized_mysql>
        </default>
    </profiles>
</clickhouse>
