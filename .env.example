APP_NAME=Medallion Backend
APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
DAGSTER_POSTGRES_DB=dagster

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_RAW_BUCKET=raw
S3_SILVER_BUCKET=silver
S3_GOLD_BUCKET=gold
PRESIGN_EXPIRATION_SECONDS=3600

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=gold

ENABLE_API_KEY_AUTH=true
SEED_DEV_API_KEY=dev-local-key
ENABLE_AUDIT_TRAIL=true
AUDIT_TRAIL_EXEMPT_PATHS=/health,/docs,/openapi.json,/redoc
ENABLE_RATE_LIMIT=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/health,/docs,/openapi.json,/redoc
ENABLE_WEBHOOK_NOTIFICATIONS=false
NOTIFICATION_WEBHOOK_URLS=
NOTIFICATION_EVENTS=ingestion_job.failed,pipeline_run.failed
NOTIFICATION_TIMEOUT_SECONDS=5
RETENTION_PIPELINE_RUN_DAYS=90
RETENTION_PREFLIGHT_ATTEMPT_DAYS=30
RETENTION_QUALITY_RESULT_DAYS=90
RETENTION_INGESTION_JOB_DAYS=180
DAGSTER_WEBSERVER_URL=http://dagster-webserver:3000
DUCKDB_THREADS=4

# Optional file-backed secret resolution:
# SECRETS_DIR=./infra/secrets
# POSTGRES_PASSWORD_FILE=./infra/secrets/POSTGRES_PASSWORD
# S3_ACCESS_KEY_FILE=./infra/secrets/S3_ACCESS_KEY
# S3_SECRET_KEY_FILE=./infra/secrets/S3_SECRET_KEY
# CLICKHOUSE_PASSWORD_FILE=./infra/secrets/CLICKHOUSE_PASSWORD
# SEED_DEV_API_KEY_FILE=./infra/secrets/SEED_DEV_API_KEY
